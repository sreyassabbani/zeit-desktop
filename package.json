{
  "name": "zeit-desktop",
  "private": true,
  "description": "A fast, native-rendered desktop calendar built around attention and surface-priority rules.",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "bootstrap:skills": "bunx skills add vercel-labs/native",
    "build": "native build",
    "check": "bun run typecheck && native check",
    "dev": "native dev",
    "doctor": "native doctor",
    "skills:native": "native skills list",
    "skills:native:automation": "native skills get automation",
    "skills:native:core": "native skills get core --full",
    "skills:native:ts": "native skills get ts-core",
    "skills:native:ui": "native skills get native-ui",
    "test": "bun run test:unit && bun run test:native",
    "test:native": "native test",
    "test:unit": "bun test ./tests",
    "typecheck": "tsc -p tsconfig.json",
    "verify": "bun run check && bun run test && bun run build"
  },
  "dependencies": {
    "@native-sdk/core": "0.5.1"
  },
  "devDependencies": {
    "@native-sdk/cli": "0.5.1",
    "typescript": "5.9.3"
  }
}
